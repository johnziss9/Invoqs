@using Invoqs.Models

<div class="modal show d-block" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-bar-chart-line me-2"></i>
                    Μηνιαία Αναφορά
                </h5>
                <button type="button" class="btn-close" @onclick="Close"></button>
            </div>
            <div class="modal-body">

                <!-- Month / Year Picker -->
                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Μήνας</label>
                        <select class="form-select" @bind="selectedMonth">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">@monthNames[i - 1]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Έτος</label>
                        <select class="form-select" @bind="selectedYear">
                            @foreach (var year in availableYears)
                            {
                                <option value="@year">@year</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-primary w-100" @onclick="LoadReport" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            else
                            {
                                <i class="bi bi-search me-1"></i>
                            }
                            Φόρτωση
                        </button>
                    </div>
                </div>

                @if (hasLoaded)
                {
                    <!-- Jobs Section -->
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-header bg-success text-white py-2">
                            <h6 class="mb-0">
                                <i class="bi bi-briefcase me-2"></i>
                                Εργασίες — @monthNames[selectedMonth - 1] @selectedYear
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fw-bold fs-5">Σύνολο Εργασιών</span>
                                <span class="badge bg-success fs-6 px-3 py-2">@totalJobs</span>
                            </div>

                            <div class="row g-2 mb-3">
                                @foreach (var kvp in jobsByType)
                                {
                                    <div class="col-6">
                                        <div class="d-flex justify-content-between border-bottom pb-1">
                                            <span class="text-muted small">@GetJobTypeDisplay(kvp.Key)</span>
                                            <span class="fw-semibold small">@kvp.Value</span>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="d-flex gap-3">
                                <small class="text-success">
                                    <i class="bi bi-check-circle me-1"></i>
                                    Τιμολογημένες: <strong>@invoicedJobs</strong>
                                </small>
                                <small class="text-warning">
                                    <i class="bi bi-clock me-1"></i>
                                    Μη Τιμολογημένες: <strong>@uninvoicedJobs</strong>
                                </small>
                            </div>
                        </div>
                    </div>

                    <!-- Invoices Section -->
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-info text-white py-2">
                            <h6 class="mb-0">
                                <i class="bi bi-receipt me-2"></i>
                                Τιμολόγια — @monthNames[selectedMonth - 1] @selectedYear
                            </h6>
                        </div>
                        <div class="card-body">
                            @foreach (var kvp in invoicesByStatus)
                            {
                                var (count, total) = kvp.Value;
                                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                                    <div>
                                        <span class="badge @GetStatusBadgeClass(kvp.Key) me-2">@GetStatusDisplay(kvp.Key)</span>
                                        <span class="text-muted small">@count τιμολόγια</span>
                                    </div>
                                    <span class="fw-semibold">€@total.ToString("N2")</span>
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-center pt-3">
                                <span class="fw-bold text-success fs-6">
                                    <i class="bi bi-cash-coin me-1"></i>
                                    Εισπραχθέντα
                                </span>
                                <span class="fw-bold text-success fs-5">€@totalReceived.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                }

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="Close">Κλείσιμο</button>
            </div>
        </div>
    </div>
</div>
<div class="modal-backdrop fade show"></div>
