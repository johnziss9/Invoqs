@using Invoqs.Models

<div class="modal show d-block email-selection-modal-overlay" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-envelope-check me-2"></i>
                    Επιλογή Email για Αποστολή
                </h5>
                <button type="button" class="btn-close" @onclick="OnCancel"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <p class="text-muted">
                        Επιλέξτε σε ποια email θέλετε να στείλετε @DocumentType για τον/την <strong>@CustomerName</strong>:
                    </p>
                </div>

                <div class="mb-3">
                    @foreach (var email in AvailableEmails)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="email_@email.GetHashCode()"
                                   checked="@IsEmailSelected(email)"
                                   @onchange="@(() => ToggleEmail(email))">
                            <label class="form-check-label" for="email_@email.GetHashCode()">
                                <i class="bi bi-envelope me-1"></i>@email
                            </label>
                        </div>
                    }
                </div>

                <div class="d-flex gap-2 mb-3">
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="SelectAll">
                        <i class="bi bi-check-all me-1"></i>
                        Επιλογή Όλων
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="DeselectAll">
                        <i class="bi bi-x-lg me-1"></i>
                        Αποεπιλογή Όλων
                    </button>
                </div>

                <div class="alert alert-info email-selection-count-alert">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>@SelectedEmails.Count</strong> email επιλεγμένα
                </div>

                @if (SelectedEmails.Count == 0)
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Πρέπει να επιλέξετε τουλάχιστον έναν email
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="OnCancel">
                    Ακύρωση
                </button>
                <button type="button"
                        class="btn btn-success"
                        @onclick="OnConfirm"
                        disabled="@(SelectedEmails.Count == 0)">
                    <i class="bi bi-send me-1"></i>
                    Αποστολή σε @SelectedEmails.Count Email
                </button>
            </div>
        </div>
    </div>
</div>