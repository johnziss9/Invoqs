@rendermode InteractiveServer
@page "/customers/bulk-email/history"
@using Invoqs.Components.UI
@using Invoqs.Models

<PageTitle>Ιστορικό Email - Invoqs</PageTitle>

<Navbar />

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/dashboard" class="text-decoration-none">Πίνακας Ελέγχου</a></li>
            <li class="breadcrumb-item"><a href="/customers" class="text-decoration-none">Πελάτες</a></li>
            <li class="breadcrumb-item"><a href="/customers/bulk-email" class="text-decoration-none">Μαζική Αποστολή Email</a></li>
            <li class="breadcrumb-item active" aria-current="page">Ιστορικό</li>
        </ol>
    </nav>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
        </div>
    }

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="text-primary mb-1">
                        <i class="bi bi-clock-history me-2"></i>Ιστορικό Αποστολών Email
                    </h2>
                    <p class="text-muted mb-0">Αρχείο όλων των μαζικών αποστολών email</p>
                </div>
                <a href="/customers/bulk-email" class="btn btn-primary mt-2 mt-md-0">
                    <i class="bi bi-envelope-paper me-1"></i>Νέα Αποστολή
                </a>
            </div>
        </div>
    </div>

    <!-- History Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="d-flex justify-content-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Φόρτωση...</span>
                    </div>
                </div>
            }
            else if (!logs.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Δεν υπάρχουν αποστολές ακόμα</h5>
                    <p>Οι μαζικές αποστολές email θα εμφανίζονται εδώ.</p>
                    <a href="/customers/bulk-email" class="btn btn-primary">
                        <i class="bi bi-envelope-paper me-1"></i>Πρώτη Αποστολή
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ημερομηνία</th>
                                <th>Θέμα</th>
                                <th>Αποστολέας</th>
                                <th>Γλώσσα</th>
                                <th class="text-center">Παραλήπτες</th>
                                <th class="text-center">Επιτυχία</th>
                                <th class="text-center">Αποτυχία</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in logs)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-semibold">@log.SentDate.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                        <br>
                                        <small class="text-muted">@log.SentDate.ToLocalTime().ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        <span class="text-truncate d-inline-block" style="max-width: 250px;" title="@log.Subject">
                                            @log.Subject
                                        </span>
                                    </td>
                                    <td><span class="text-muted">@log.SentByUserName</span></td>
                                    <td>
                                        <span class="badge @(log.Language == "el" ? "bg-primary" : "bg-info")">
                                            @(log.Language == "el" ? "ΕΛ" : "EN")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@log.TotalRecipients</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success">@log.SentCount</span>
                                    </td>
                                    <td class="text-center">
                                        @if (log.FailedCount > 0)
                                        {
                                            <span class="badge bg-danger">@log.FailedCount</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewDetails(log.Id)">
                                            <i class="bi bi-eye me-1"></i>Λεπτομέρειες
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Detail Modal -->
@if (selectedLog != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-envelope-open me-2"></i>Λεπτομέρειες Αποστολής
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"
                            disabled="@isLoadingDetail"></button>
                </div>
                <div class="modal-body">
                    @if (isLoadingDetail)
                    {
                        <div class="d-flex justify-content-center py-4">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    }
                    else
                    {
                        <!-- Meta info -->
                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <small class="text-muted text-uppercase fw-semibold">Ημερομηνία</small>
                                <p class="mb-0">@selectedLog.SentDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="col-sm-6">
                                <small class="text-muted text-uppercase fw-semibold">Αποστολέας</small>
                                <p class="mb-0">@selectedLog.SentByUserName</p>
                            </div>
                            <div class="col-sm-6">
                                <small class="text-muted text-uppercase fw-semibold">Γλώσσα</small>
                                <p class="mb-0">@(selectedLog.Language == "el" ? "Ελληνικά" : "English")</p>
                            </div>
                            <div class="col-sm-6">
                                <small class="text-muted text-uppercase fw-semibold">Αποτέλεσμα</small>
                                <p class="mb-0">
                                    <span class="badge bg-success me-1">@selectedLog.SentCount επιτυχή</span>
                                    @if (selectedLog.FailedCount > 0)
                                    {
                                        <span class="badge bg-danger">@selectedLog.FailedCount αποτυχίες</span>
                                    }
                                </p>
                            </div>
                        </div>

                        <!-- Email preview -->
                        <div class="card bg-light mb-4">
                            <div class="card-body">
                                <small class="text-muted text-uppercase fw-semibold">Θέμα</small>
                                <p class="fw-semibold mb-3">@selectedLog.Subject</p>
                                <small class="text-muted text-uppercase fw-semibold">Μήνυμα</small>
                                <p class="mb-0 small text-muted body-preview">@selectedLog.Body</p>
                            </div>
                        </div>

                        <!-- Recipients -->
                        <h6 class="mb-2"><i class="bi bi-people me-1"></i>Παραλήπτες (@selectedLog.TotalRecipients)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Πελάτης</th>
                                        <th>Email</th>
                                        <th class="text-center">Κατάσταση</th>
                                        <th>Σφάλμα</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in selectedLog.Recipients.OrderBy(r => r.CustomerName))
                                    {
                                        <tr class="@(!r.Success ? "table-danger" : "")">
                                            <td>@r.CustomerName</td>
                                            <td class="text-muted small">@r.Email</td>
                                            <td class="text-center">
                                                @if (r.Success)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                                }
                                            </td>
                                            <td class="text-muted small">@r.Error</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">
                        <i class="bi bi-x me-1"></i>Κλείσιμο
                    </button>
                </div>
            </div>
        </div>
    </div>
}
